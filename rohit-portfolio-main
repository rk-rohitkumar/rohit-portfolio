        .job-card h3 {
            color: #007BFF;
            margin-top: 0;
        }
        .metadata p {
            margin: 5px 0;
            font-size: 0.9em;
        }
        .responsibilities ul, .impact-list li {
            margin: 5px 0 10px 0;
            padding-left: 20px;
