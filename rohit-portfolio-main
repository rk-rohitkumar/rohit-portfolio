        footer {
            background-color: #343a40;
            color: white;
            text-align: center;
            padding: 40px 0;
        }
        .social-links a {
            color: white;
            margin: 0 15px;
            font-size: 1.5em;
            text-decoration: none;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.5em;
            }
            .value-card {
                flex-basis: 100%; /* Stack cards on mobile */
